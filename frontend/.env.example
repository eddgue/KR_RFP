# frontend/.env.example — copy to .env.local for local dev (gitignored, never committed).
# NEXT_PUBLIC_* vars are exposed to the browser by Next.js, so they hold no secrets —
# only the public API base URL. Auth tokens are handled at the edge (Security/DEP-4), not here.

# Base URL of the FastAPI backend. Local compose serves the API on :8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
