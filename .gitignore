# ---- secrets & env (never commit) ----
**/.env
**/.env.*
!**/.env.example
*.pem
*.key

# ---- clean-room quarantine: real sample data not committed until classified (ADR-0001, Security) ----
reference/samples/*
!reference/samples/.gitkeep
!reference/samples/README.md

# ---- python (backend) ----
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# ---- node (frontend) ----
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- os / editor ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ---- local infra ----
infra/postgres/data/
*.local

# clean-room: v3 engine read as reference, logic lifted into our own code, raw never committed (ADR-0001)
reference/v3-engine/

# generated demo artifacts (regenerated each run; synthetic)
backend/demo/output/

# ---- claude code transient agent worktrees (auto-cleaned; never commit) ----
.claude/worktrees/
.claude/settings.local.json
