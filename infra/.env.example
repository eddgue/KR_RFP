# infra/.env.example — compose-level env contract (DevOps PLAN §2).
# Copy to infra/.env and fill in. .env is gitignored and NEVER committed (ADR-0001 §4).
# These are SAFE PLACEHOLDERS for local dev only — not secrets, not real credentials.
# CI and prod inject the same variable NAMES from their secret store; only the VALUES differ.

# ---- Postgres container (the `db` service) ----
POSTGRES_USER=kr_rfp
POSTGRES_PASSWORD=kr_rfp
POSTGRES_DB=kr_rfp

# ---- Backend (the `backend` service) ----
# Host is the compose service name `db`. The backend's own .env uses the same URL shape;
# only the host differs (db over the compose network, localhost when run on the host).
# Driver is psycopg (v3) to match SQLAlchemy 2.x + Alembic in backend/.
DATABASE_URL=postgresql+psycopg://kr_rfp:kr_rfp@db:5432/kr_rfp
APP_ENV=dev
