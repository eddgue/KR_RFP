# Backend environment contract (copy to .env; never commit real .env — see .gitignore).
# All settings are consumed by app/core/config/settings.py (pydantic-settings).

# PostgreSQL connection URL (SQLAlchemy + Alembic both read this).
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/kr_rfp

# Deployment environment: local | ci | staging | production
ENV=local

# Engine implementation selector (D2 is in spike). "stub" = DeterministicStubEngine.
ENGINE_IMPL=stub

# Default tenant code used by local dev/seed only. Real tenant context comes from the
# verified token at the edge — NEVER from this value at runtime (security/PLAN §1).
DEFAULT_TENANT_CODE=KR-DEFAULT
